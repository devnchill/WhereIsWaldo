generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Round {
    id           String    @id @default(uuid()) 
    userName     String? 
    startTime    DateTime  @default(now()) 
    endTime      DateTime? 
    durationMs   Int? 
    correctCount Int       @default(0) 
    totalCount   Int	   @default(36) 
    completed    Boolean   @default(false) 
}
